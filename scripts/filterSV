#!/usr/bin/env python
# created on Wed Jul 16 2025

## Required modules
import argparse, sys, eaglec

currentVersion = eaglec.__version__

def getargs():
    
    parser = argparse.ArgumentParser(
        description='''Filter EagleC2 SV calls using probability, FCN score, refinement score,
        gap status, and chromosome-boundary status.''',
        formatter_class=argparse.ArgumentDefaultsHelpFormatter
    )

    parser.add_argument('-v', '--version', action='version',
                        version=' '.join(['%(prog)s',currentVersion]),
                        help='Print version number and exit.')

    # Input/Output
    parser.add_argument('-i', '--input-file', required=True,
                        help='Path to a .txt file generated by the predictSV command.')
    parser.add_argument('-o', '--output', required=True,
                        help='Output file name.')

    parser.add_argument('--prob-cutoff', type=float, default=0.2,
                        help='Global minimum SV probability cutoff.')
    parser.add_argument('--prob-cutoffs',
                        help='Resolution-specific probability cutoffs, e.g. "5000:0.3,10000:0.5".')
    parser.add_argument('--fcn-cutoff', type=float, default=0.0,
                        help='Minimum FCN scanning score.')
    parser.add_argument('--refine-cutoff', type=float, default=0.0,
                        help='Minimum refinement score.')
    parser.add_argument('--max-gap', type=int, default=2,
                        help='Maximum allowed gap_x + gap_y.')
    parser.add_argument('--keep-boundary-svs', action='store_true',
                        help='Keep SVs near chromosome boundaries.')

    ## Parse the command-line arguments
    commands = sys.argv[1:]
    if not commands:
        commands.append('-h')
    args = parser.parse_args(commands)

    return args, commands

def parse_prob_cutoffs(cutoff_str):

    cutoffs = {}
    if cutoff_str:
        for item in cutoff_str.split(','):
            res, val = item.split(':')
            cutoffs[int(res)] = float(val)

    return cutoffs



def parse_eaglec2_file(filepath):

    pool = {}
    header = ""
    with open(filepath, 'r') as source:
        header = source.readline().rstrip()

        for line in source:
            raw = line.rstrip('\n')
            parts = raw.split('\t')

            if len(parts) < 13:
                continue

            c1, p1_str, c2, p2_str = parts[:4]
            p1, p2 = int(p1_str), int(p2_str)

            # normalize ordering
            if (c1 > c2) or (c1 == c2 and p1 > p2):
                c1, c2 = c2, c1
                p1, p2 = p2, p1

            probs = [float(x) for x in parts[4:10]]
            res_origin = int(parts[10])
            res_finemapped = int(parts[11])

            info = parts[12]
            tokens = info.split(',')

            if len(tokens) < 6:
                continue

            try:
                gap_x = int(tokens[0])
                gap_y = int(tokens[1])
                bx = int(tokens[2])
                by = int(tokens[3])
                fcn_score = float(tokens[4])
                refine_score = float(tokens[5])
            except ValueError:
                continue

            key = (c1, c2, p1, p2, res_origin, res_finemapped)

            pool[key] = {
                'line': raw + '\n',
                'probs': probs,
                'res_origin': res_origin,
                'res_finemapped': res_finemapped,
                'gap_x': gap_x,
                'gap_y': gap_y,
                'bx': bx,
                'by': by,
                'fcn_score': fcn_score,
                'refine_score': refine_score
            }

    return pool, header

def keep_sv(data, args, prob_cutoffs):

    prob_max = max(data['probs'])
    res = data['res_origin']

    # resolution-specific cutoff
    cutoff = prob_cutoffs.get(res, args.prob_cutoff)

    if prob_max < cutoff:
        return False

    # boundary filter
    if not args.keep_boundary_svs:
        if data['bx'] == 1 or data['by'] == 1:
            return False

    # gap filter
    if data['gap_x'] + data['gap_y'] > args.max_gap:
        return False

    # FCN score
    if data['fcn_score'] < args.fcn_cutoff:
        return False

    # refinement score
    if data['refine_score'] < args.refine_cutoff:
        return False

    return True


def run():
    args, commands = getargs()

    if commands[0] not in ['-h', '-v', '--help', '--version']:

        sv_pool, header = parse_eaglec2_file(args.input_file)
        print(f"Loaded {len(sv_pool)} SVs")

        prob_cutoffs = parse_prob_cutoffs(args.prob_cutoffs)

        svs_filtered = {}

        for key, data in sv_pool.items():
            if keep_sv(data, args, prob_cutoffs):
                svs_filtered[key] = data['line']

        print(f"Retained {len(svs_filtered)} SVs after filtering")

        with open(args.output, 'w') as out:
            out.write(header + '\n')
            for key in sorted(svs_filtered.keys()):
                out.write(svs_filtered[key])

if __name__ == '__main__':
    run()